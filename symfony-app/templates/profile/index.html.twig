{% extends 'base.html.twig' %}

{% block title %}Profile - {{ user.username }}{% endblock %}

{% block styles %}<link rel="stylesheet" href="{{ asset('css/profile.css') }}">{% endblock %}

{% block body %}
    <div class="profile-container">
        <div class="profile-header">
            <div class="profile-avatar">
                {{ user.username|slice(0, 1)|upper }}
            </div>
            <h1 class="profile-username">
                {% if user.name %}
                    {{ user.name }} {{ user.lastName|default('') }}
                {% else %}
                    {{ user.username }}
                {% endif %}
            </h1>
            <div class="profile-handle">@{{ user.username }}</div>
        </div>

        <div class="profile-details">
            <div class="profile-field">
                <div class="profile-field-label">Email</div>
                <div class="profile-field-value">{{ user.email }}</div>
            </div>

            {% if user.age %}
                <div class="profile-field">
                    <div class="profile-field-label">Age</div>
                    <div class="profile-field-value">{{ user.age }} years old</div>
                </div>
            {% endif %}

            {% if user.name %}
                <div class="profile-field">
                    <div class="profile-field-label">Full Name</div>
                    <div class="profile-field-value">
                        {{ user.name }}
                        {% if user.lastName %}
                            {{ user.lastName }}
                        {% endif %}
                    </div>
                </div>
            {% endif %}
        </div>

        {% if user.bio %}
            <div class="profile-bio">
                <div class="profile-bio-label">About Me</div>
                <div class="profile-bio-text">{{ user.bio }}</div>
            </div>
        {% endif %}

        <div class="profile-stats">
            <div class="stat-item">
                <div class="stat-number">{{ user.photoCount }}</div>
                <div class="stat-label">Photos</div>
            </div>
        </div>

        <div class="integration-section">
            <div class="integration-title">External Integrations</div>
            <form method="POST" action="{{ path('save_integration') }}" class="integration-form">
                <input type="hidden" name="_token" value="{{ csrf_token('save_integration') }}">
                <div class="form-group">
                    <label for="provider">Provider</label>
                    <select id="provider" name="provider" class="form-select">
                        {% for provider in providers %}
                            <option value="{{ provider.value }}" {{ user.phoenixApiToken and provider.value == 'phoenix_api' ? 'selected' : '' }}>
                                {{ provider.name }}
                            </option>
                        {% endfor %}
                    </select>
                </div>
                <div class="form-group">
                    <label for="token">Access Token</label>
                    <input type="text" id="token" name="token" value="{{ user.phoenixApiToken }}" placeholder="Enter your access token">
                </div>
                <button type="submit" class="btn-save">Save Token</button>
            </form>

            {% if user.phoenixApiToken %}
                <div class="import-section">
                    <form method="POST" action="{{ path('photos_import') }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('photos_import') }}">
                        <button type="submit" class="btn-import">Import Photos from Phoenix API</button>
                    </form>
                </div>
            {% endif %}
        </div>

        <div style="text-align: center;">
            <a href="{{ path('home') }}" class="back-button">← Back to Gallery</a>
        </div>
    </div>
{% endblock %}
