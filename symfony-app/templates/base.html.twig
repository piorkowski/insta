<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Symfony App{% endblock %}</title>
    <link rel="stylesheet" href="{{ asset('css/app.css') }}">
    {% block styles %}{% endblock %}
</head>
<body>
    {% for type, messages in app.flashes %}
        <div class="flash-messages">
            {% for message in messages %}
                <div class="flash-message {{ type }}">
                    {{ message }}
                </div>
            {% endfor %}
        </div>
    {% endfor %}
    
    {% if app.user %}
        <div class="profile-menu">
            <a href="{{ path('profile') }}" class="profile-icon" title="My Profile">
                👤
            </a>
            <div class="profile-dropdown">
                <a href="{{ path('profile') }}">👤 My Profile</a>
                <div class="profile-dropdown-separator"></div>
                <a href="{{ path('logout') }}">🚪 Logout</a>
            </div>
        </div>
    {% endif %}
    
    <div class="container">
        <header>
            <h1>📸 Symfony App</h1>
            <p>Discover amazing photography from our community</p>
        </header>
        
        {% block body %}{% endblock %}
    </div>
</body>
</html>

