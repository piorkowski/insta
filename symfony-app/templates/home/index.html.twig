{% extends 'base.html.twig' %}

{% block styles %}<link rel="stylesheet" href="{{ asset('css/home.css') }}">{% endblock %}

{% block body %}
    <div class="filter-bar">
        <form method="GET" action="{{ path('home') }}">
            <div class="filter-group">
                <label for="location">Location</label>
                <input type="text" id="location" name="location" value="{{ filters.location }}" placeholder="e.g. Alps">
            </div>
            <div class="filter-group">
                <label for="camera">Camera</label>
                <input type="text" id="camera" name="camera" value="{{ filters.camera }}" placeholder="e.g. Canon">
            </div>
            <div class="filter-group">
                <label for="description">Description</label>
                <input type="text" id="description" name="description" value="{{ filters.description }}" placeholder="e.g. sunset">
            </div>
            <div class="filter-group">
                <label for="taken_at_from">Taken from</label>
                <input type="date" id="taken_at_from" name="taken_at_from" value="{{ filters.takenAtFrom ?? '' }}">
            </div>
            <div class="filter-group">
                <label for="taken_at_to">Taken to</label>
                <input type="date" id="taken_at_to" name="taken_at_to" value="{{ filters.takenAtTo ?? '' }}">
            </div>
            <div class="filter-group">
                <label for="username">Username</label>
                <input type="text" id="username" name="username" value="{{ filters.username }}" placeholder="e.g. nature_lover">
            </div>
            <div class="filter-buttons">
                <button type="submit" class="btn-filter">Filter</button>
                <a href="{{ path('home') }}" class="btn-clear">Clear</a>
            </div>
        </form>
    </div>

    {% if photos|length > 0 %}
        <div class="photo-grid">
            {% for photo in photos %}
                <div class="photo-card">
                    <div class="photo-image-container">
                        <img src="{{ photo.imageUrl }}" alt="{{ photo.description }}">
                        {% if currentUserId %}
                            <form method="POST" action="{{ path('photo_like', {id: photo.id}) }}" style="display:inline">
                                <input type="hidden" name="_token" value="{{ csrf_token('photo_like_' ~ photo.id) }}">
                                <button type="submit" class="like-button {{ photo.isLikedByCurrentUser ? 'liked' : '' }}">
                                    {{ photo.isLikedByCurrentUser ? '❤️' : '🤍' }}
                                    <span>{{ photo.likeCounter }}</span>
                                </button>
                            </form>
                        {% else %}
                            <span class="like-button disabled" title="Login to like">
                                🤍
                                <span>{{ photo.likeCounter }}</span>
                            </span>
                        {% endif %}
                    </div>
                    <div class="photo-info">
                        <div class="photo-description">
                            {{ photo.description|default('No description provided') }}
                        </div>

                        <div class="photo-meta">
                            {% if photo.location %}
                                <div class="photo-meta-item">
                                    <span>📍</span>
                                    <strong>Location:</strong> {{ photo.location }}
                                </div>
                            {% endif %}

                            {% if photo.camera %}
                                <div class="photo-meta-item">
                                    <span>📷</span>
                                    <strong>Camera:</strong> {{ photo.camera }}
                                </div>
                            {% endif %}

                            {% if photo.takenAt %}
                                <div class="photo-meta-item">
                                    <span>📅</span>
                                    <strong>Date:</strong> {{ photo.takenAt|date('M d, Y') }}
                                </div>
                            {% endif %}
                        </div>

                        <div class="author">
                            <div class="author-avatar">
                                {{ photo.username|slice(0, 1)|upper }}
                            </div>
                            <div class="author-info">
                                <div class="author-name">
                                    {% if photo.userName %}
                                        {{ photo.userName }} {{ photo.userLastName|default('') }}
                                    {% else %}
                                        {{ photo.username }}
                                    {% endif %}
                                </div>
                                <div class="author-username">@{{ photo.username }}</div>
                            </div>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% else %}
        <div class="empty-state">
            <h2>📷 No photos found</h2>
            <p>Try adjusting your filters or be the first to share your photography!</p>
        </div>
    {% endif %}
{% endblock %}
